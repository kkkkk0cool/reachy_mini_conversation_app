# Realtime backend to use: "huggingface", "openai", "gemini", or "glm"
# Defaults to "huggingface" when unset.
# BACKEND_PROVIDER="huggingface"
# Optional model override for OpenAI Realtime, Gemini Live, or GLM Realtime.
# Hugging Face uses the server's model selection and ignores MODEL_NAME.
# MODEL_NAME="gpt-realtime"
# GLM model options: glm-realtime (default), glm-realtime-flash (9B), glm-realtime-air (32B)
# MODEL_NAME="glm-realtime"

# Set up your API key according to your backend
OPENAI_API_KEY=
# GEMINI_API_KEY=
# GLM_API_KEY=       # Zhipu AI API key from https://open.bigmodel.cn/
# ZHIPUAI_API_KEY=   # Alias for GLM_API_KEY

# ── GLM Chat text pipeline (ASR → GLM-4.x → Edge-TTS) ────────────────────────
# Requires: pip install 'reachy_mini_conversation_app[glm_chat]'
# Supported models: glm-4.7 (default), glm-4.7-flash, glm-4.7-vision
# BACKEND_PROVIDER=glm_chat
# MODEL_NAME=glm-4.7

# ── FunASR + Qwen/DeepSeek + CosyVoice local pipeline ─────────────────────────
# Step 1: pip install 'reachy_mini_conversation_app[funasr_pipeline]'
# Step 2: Clone and install CosyVoice:
#   git clone --recursive https://github.com/FunAudioLLM/CosyVoice.git
#   cd CosyVoice && pip install -e .
# Step 3: Download CosyVoice2-0.5B model (~1 GB):
#   python -c "from modelscope import snapshot_download; \
#     snapshot_download('iic/CosyVoice2-0.5B', local_dir='pretrained_models/CosyVoice2-0.5B')"
#
# BACKEND_PROVIDER=funasr_pipeline
#
# LLM selection: "qwen" (default) or "deepseek"
# TEXT_LLM_PROVIDER=qwen
#
# Qwen (DashScope) — get key at https://console.aliyun.com/
# QWEN_API_KEY=sk-...
# DASHSCOPE_API_KEY=sk-...    # alias for QWEN_API_KEY
# Supported Qwen models: qwen-turbo, qwen-plus, qwen-max, qwen-long, qwen3-235b-a22b
# MODEL_NAME=qwen-turbo
#
# DeepSeek — get key at https://platform.deepseek.com/
# DEEPSEEK_API_KEY=sk-...
# Supported DeepSeek models: deepseek-chat, deepseek-reasoner
# MODEL_NAME=deepseek-chat
#
# FunASR model (downloads automatically on first run, ~250 MB)
# FUNASR_MODEL=iic/SenseVoiceSmall
#
# CosyVoice2 model directory
# COSYVOICE_MODEL_DIR=pretrained_models/CosyVoice2-0.5B
#
# Mac inference server TTS provider:
#   cosyvoice = local CosyVoice2, no network, more controllable but slower/mechanical
#   edge     = Microsoft Edge TTS, online, usually faster and more natural
# INFERENCE_TTS_PROVIDER=cosyvoice
# EDGE_TTS_VOICE=zh-CN-XiaoxiaoNeural
#
# Optional remote action planner:
#   enabled = ask the text LLM for a separate JSON action plan before the spoken reply.
#   timeout = short timeout; on timeout/failure the server falls back to deterministic keywords.
# REACHY_ACTION_PLANNER_ENABLED=1
# REACHY_ACTION_PLANNER_TIMEOUT=0.8

# ── Remote inference server (Mac M4 Pro hosts all AI; Pi 4 is a thin client) ─
#
# RECOMMENDED: full pipeline on Mac (ASR + LLM API + TTS in one call)
#
#   Step 1 — On Mac, configure LLM and start the server.
#   Pick ONE of the following LLM options:
#
#   Option A — Cloud API (Qwen / DeepSeek / GLM):
#     TEXT_LLM_PROVIDER=qwen           # or "deepseek" / "glm"
#     QWEN_API_KEY=sk-...              # DashScope  (TEXT_LLM_PROVIDER=qwen)
#     DEEPSEEK_API_KEY=sk-...          # DeepSeek   (TEXT_LLM_PROVIDER=deepseek)
#     GLM_API_KEY=...                  # Zhipu AI   (TEXT_LLM_PROVIDER=glm)
#     MODEL_NAME=qwen-turbo            # or glm-4.7 / glm-4-flash / deepseek-chat
#
#   Option B — Local Hermes agent via Ollama (no API key, history compression + personalization):
#     TEXT_LLM_PROVIDER=hermes
#     MODEL_NAME=nous-hermes-2-mistral  # any model pulled with: ollama pull <name>
#     HERMES_API_URL=http://localhost:11434/v1   # default; change for LM Studio / vLLM
#     # Configure personality / memory in the Ollama Modelfile (system prompt, context length, etc.)
#
#     reachy-mini-inference-server
#
#   Step 2 — On Pi 4, set only these two vars:
# BACKEND_PROVIDER=remote
# CONVERSATION_SERVICE_URL=http://192.168.x.x:8765/conversation
#
# ── Advanced: split ASR+TTS (Pi 4 calls LLM cloud directly) ─────────────────
# FUNASR_SERVICE_URL=http://192.168.x.x:8765/asr
# TTS_SERVICE_URL=http://192.168.x.x:8765/tts
#
# inference_server listen settings (Mac side, optional)
# INFERENCE_SERVER_HOST=0.0.0.0
# INFERENCE_SERVER_PORT=8765

# Hugging Face connection mode: "deployed" or "local".
# Deployed mode uses the built-in Hugging Face server.
# Defaults to "deployed" when unset.
# HF_REALTIME_CONNECTION_MODE="deployed"

# Direct Hugging Face realtime endpoint for local/LAN backends.
# Accepts either the base URL (`ws://127.0.0.1:8765/v1`) or the full realtime URL
# (`ws://127.0.0.1:8765/v1/realtime`). Used when HF_REALTIME_CONNECTION_MODE=local.
# HF_REALTIME_WS_URL="ws://127.0.0.1:8765/v1/realtime"

# Local vision model (only used with --local-vision CLI flag)
# By default, vision is handled by the selected realtime backend when the camera tool is used
LOCAL_VISION_MODEL=HuggingFaceTB/SmolVLM2-2.2B-Instruct

# Cache for local VLM (only used with --local-vision CLI flag)
HF_HOME=./cache

# Hugging Face token for accessing datasets/models
HF_TOKEN=

# Optional external profile/tool directories
# REACHY_MINI_EXTERNAL_PROFILES_DIRECTORY=external_content/external_profiles
# REACHY_MINI_EXTERNAL_TOOLS_DIRECTORY=external_content/external_tools

# Optional: discover and auto-load all tools found in REACHY_MINI_EXTERNAL_TOOLS_DIRECTORY,
# even if they are not listed in the selected profile's tools.txt.
# This is convenient for downloaded tools used with built-in/default profiles.
# AUTOLOAD_EXTERNAL_TOOLS=1

# Optional: lower this if motor communication errors appear while the control UI
# is also polling full robot state. Default is 45 Hz.
# REACHY_MOTION_CONTROL_HZ=45
